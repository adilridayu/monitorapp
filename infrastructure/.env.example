# ============================================
# WAREHOUSE INTELLIGENCE MONITORING SYSTEM
# Environment Configuration
# ============================================
# Copy this file to .env and update values as needed

# ============================================
# GENERAL SETTINGS
# ============================================
NODE_ENV=development
APP_ENV=development

# ============================================
# POSTGRES DATABASE
# ============================================
POSTGRES_USER=warehouse_admin
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=warehouse_db
POSTGRES_PORT=5432

# ============================================
# MONGODB
# ============================================
MONGO_USER=mongo_admin
MONGO_PASSWORD=change_this_secure_password_123
MONGO_PORT=27017

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=change_this_secure_password_123
REDIS_PORT=6379

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_USER=rabbitmq_admin
RABBITMQ_PASSWORD=change_this_secure_password_123
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Change these in production!
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_minimum_32_characters_long
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# SERVICE PORTS
# ============================================
BACKEND_PORT=3000
AI_PORT=8000
NGINX_PORT=80
NGINX_SSL_PORT=443
ADMINER_PORT=8080

# ============================================
# AI SERVICE CONFIGURATION
# ============================================
AI_MODEL_PATH=/app/models
AI_BATCH_SIZE=32
AI_CONFIDENCE_THRESHOLD=0.7
AI_ANOMALY_THRESHOLD=0.8
AI_FORECAST_HORIZON=30

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
BACKEND_RATE_LIMIT_TTL=60
BACKEND_RATE_LIMIT_MAX=100

# ============================================
# MONITORING & ALERTING
# ============================================
ALERT_CHECK_INTERVAL_MINUTES=15
STOCK_CHECK_INTERVAL_MINUTES=30
FORECAST_GENERATION_INTERVAL_HOURS=24

# ============================================
# NOTIFICATION SETTINGS (Optional)
# ============================================
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=warehouse@company.com

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# ============================================
# PRODUCTION SPECIFIC (Only set in production)
# ============================================
# SSL_CERT_PATH=/etc/nginx/ssl/certificate.crt
# SSL_KEY_PATH=/etc/nginx/ssl/private.key
# ENABLE_SSL=true