# ============================================
# WAREHOUSE INTELLIGENCE BACKEND CONFIGURATION
# ============================================

# ============================================
# GENERAL SETTINGS
# ============================================
NODE_ENV=development
APP_ENV=development

# ============================================
# POSTGRES DATABASE
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=warehouse_admin
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=warehouse_db
DB_POOL_SIZE=20

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb://localhost:27017/warehouse_logs

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=300

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this_in_production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_minimum_32_characters_long_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# AI SERVICE CONFIGURATION
# ============================================
AI_SERVICE_URL=http://localhost:8000
AI_CONFIDENCE_THRESHOLD=0.7
AI_ANOMALY_THRESHOLD=0.8
AI_FORECAST_HORIZON=30

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:3000

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
HOST=0.0.0.0

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/application.log

# ============================================
# NOTIFICATION SETTINGS (Optional)
# ============================================
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=warehouse@company.com

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=